#: aef5e8f0764443159c73476641f7dd4e of
#: tensormesh.sparse.nonlinear_solve.nonlinear_solve:5
msgid ""
"This in-tree Newton-Raphson driver is **scheduled for removal**. ``torch-"
"sla`` ships a richer ``torch_sla.SparseTensor.nonlinear_solve`` (also "
"accessible as ``SparseMatrix.nonlinear_solve``) with Newton / Picard / "
"Anderson modes, Armijo line search, and an autograd-based Jacobian — so "
"the user no longer has to supply ``j``. Migrate to "
"``A.nonlinear_solve(residual, u0, *params)``; see "
":doc:`/user_guide/linear_solvers`."
msgstr ""

#: eb41fd95193049f0a6b9ee30318c4ca7 of
