#: 926b19d06b744ac59fcec75ec2e52805 of tensormesh.optimizer.oc.OCOptimizer:1
msgid "Optimality Criteria (OC) optimizer for topology optimization."
msgstr ""

#: 63b1ab12d7154442b732fe351ce45fb1 of tensormesh.optimizer.oc.OCOptimizer:3
msgid ""
"Similar interface to :obj:`torch.optim.Optimizer`, but specifically "
"designed for density-based topology optimization with volume constraints."
msgstr ""

#: 3cb6c0144757428fbf89f1608de2eaef of tensormesh.optimizer.oc.OCOptimizer:6
msgid "The OC update rule is:"
msgstr ""

#: f37c058056d6453b835463a62412475d of tensormesh.optimizer.oc.OCOptimizer:8
msgid ""
"\\rho_{\\text{new}} = \\rho \\cdot B_e^{\\eta}\n"
"\n"
msgstr ""

#: 43381b1ac7b948fd97ac03d992107b30 of tensormesh.optimizer.oc.OCOptimizer:11
msgid "where:"
msgstr ""

#: 4ed48c741d4d41519100ee7f6b620f20 of tensormesh.optimizer.oc.OCOptimizer:13
msgid ""
"B_e = \\sqrt{\\frac{-\\frac{\\partial C}{\\partial \\rho}}{\\lambda "
"\\cdot \\frac{\\partial V}{\\partial \\rho}}}\n"
"\n"
msgstr ""

#: 13fa9f3e3fd34e3cafc6380155ad6f18 of tensormesh.optimizer.oc.OCOptimizer:16
msgid ""
":math:`\\lambda`: Lagrange multiplier (found by bisection to satisfy "
"volume constraint)"
msgstr ""

#: 431c18fde7414df8830cb610cbc7a39a of tensormesh.optimizer.oc.OCOptimizer:17
msgid ":math:`\\eta = 0.5`: damping exponent"
msgstr ""

