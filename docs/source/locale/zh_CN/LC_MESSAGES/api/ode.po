#: 02e70b13b82e4cdbb9f9d5522a65364a of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta:13
#, python-brace-format
msgid ""
"\\begin{bmatrix}\n"
"M_0 - A_0\\tau a_{0,0} & -A_0\\tau a_{0,1} & \\cdots & -A_0\\tau "
"a_{0,s-1} \\\\\n"
"-A_1\\tau a_{1,0} & M_1 - A_1\\tau a_{1,1} & \\cdots & -A_1\\tau "
"a_{1,s-1} \\\\\n"
"\\vdots & \\vdots & \\ddots & \\vdots \\\\\n"
"-A_{s-1}\\tau a_{s-1,0} & -A_{s-1}\\tau a_{s-1,1} & \\cdots & M_{s-1} - "
"A_{s-1}\\tau a_{s-1,s-1}\n"
"\\end{bmatrix}\n"
"\\begin{bmatrix} k_0 \\\\ k_1 \\\\ \\vdots \\\\ k_{s-1} \\end{bmatrix}\n"
"=\n"
"\\begin{bmatrix} B_0 + A_0 u \\\\ B_1 + A_1 u \\\\ \\vdots \\\\ B_{s-1} +"
" A_{s-1} u \\end{bmatrix}"
msgstr ""

