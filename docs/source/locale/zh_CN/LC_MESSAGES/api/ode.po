#: 2ce23868f3c64f9c97352f6c9d3ee7d4 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.recover_stage:1
msgid "Lift one stage slope back from the solve space to full DOF."
msgstr ""

#: c0baead156ac49a28fb387e85a162022 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.recover_stage:3
msgid ""
"Default: identity. Override when :meth:`pre_solve_lhs` / "
":meth:`pre_solve_rhs` *reduce* the system size — e.g. static condensation"
" via :class:`~tensormesh.Condenser`. In that case each stage value "
":math:`k_i` is solved in the inner-DOF subspace and must be prolonged "
"back to the full DOF layout before being combined with :math:`u_0`."
msgstr ""

#: 14ad50dd7d8b401ab9a97e9d7457a0c1 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.recover_stage:10
msgid ""
"For Dirichlet boundary conditions the boundary entries of :math:`k_i` "
"must be **zero**, regardless of the prescribed value of :math:`u` there: "
"a Dirichlet DOF is fixed, so its time-derivative is zero. Use "
":meth:`~tensormesh.Condenser.prolong` (or an equivalent scatter-with-"
"zero-boundary) here, *not* :meth:`~tensormesh.Condenser.recover` (which "
"writes the prescribed Dirichlet value into the boundary slots)."
msgstr ""

#: beb39cdd5c8a47b492fe23eded96ca94 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.recover_stage:19
msgid "One stage slope from the solve, shape ``[D_solve]``."
msgstr ""

#: c03de400343a4da3856d3624f32ce647 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.recover_stage:22
msgid ""
"The lifted stage slope of shape ``[D]``. Default returns ``k_i`` "
"unchanged."
msgstr ""

#: f6bf7d67bd92405c88708222cb6100b9 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.post_solve:1
msgid "Postprocess the combined solution after the linear solve."
msgstr ""

#: 5c95c65d4fc04d5c9c7377b3c672a181 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.post_solve:3
msgid ""
"Runs after the stage slopes have already been lifted by "
":meth:`recover_stage` and combined with :math:`u_0`, so ``u`` is always "
"full-DOF here. Use this hook for things that act on the final state — "
"clamping, normalization, projecting onto a manifold, etc. For static-"
"condensation BCs, override :meth:`recover_stage` instead."
msgstr ""

#: b88578ce16ae4df9ba1cde9ff7eb1005 of
#: tensormesh.ode.implicit_linear_rungekutta.ImplicitLinearRungeKutta.post_solve:10
msgid "Combined solution of shape ``[D]``."
msgstr ""

