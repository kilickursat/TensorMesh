msgstr ""

#: c01439a233d6409db58a59524e026f9d of
#: tensormesh.element.element.Element.eval_cell_jacobian:3
msgid ""
"The Jacobian matrix represents the linear transformation from reference "
"coordinates to physical coordinates. It is computed by multiplying the "
"element coordinates by the gradients of the basis functions."
msgstr ""

#: 07319bcb3d3d44289422611d027f0c35 of
#: tensormesh.element.element.Element.eval_cell_jacobian:6
msgid "For each quadrature point q and element e, computes:"
