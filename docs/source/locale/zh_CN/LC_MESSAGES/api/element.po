#: 2f90e53913e34aab94641f1bcf430687 of
#: tensormesh.element.element.Element.eval_cell_jacobian:8
#, python-brace-format
msgid ""
"J_{e,q,i,j} = \\sum_b \\text{coords}_{e,b,j} \\frac{\\partial "
"\\phi_b}{\\partial x_i}(q)"
