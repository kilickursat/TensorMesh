#: 931f440750d04a4bb3335da12bf3a615 of
#: tensormesh.nn.buffer_list.BufferList.pop:1
msgid ""
"Remove and return the tensor at ``index`` (default: last), shifting "
"subsequent entries left by one."
msgstr ""

#: 122edafe2e5c46db9e6f931a4475db0c of
#: tensormesh.nn.buffer_list.BufferList.item:1
msgid "Return the sole tensor when the list has length 1; assert otherwise."
msgstr ""

