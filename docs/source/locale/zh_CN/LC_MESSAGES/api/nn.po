msgid "Iterate over ``(key, tensor)`` pairs across all three backing stores."
msgstr ""

#: 2e8dcb71251449acab5d5d0ddf3f176f of
#: tensormesh.nn.buffer_dict.BufferDict.values:1
msgid "Iterate over tensors across all three backing stores."
msgstr ""

