#: def322a840254d74ba2e6ea7c95232b3 of
#: tensormesh.operator.condense.Condenser.recover:1
msgid "Recover the full-DOF solution from an inner-DOF solution."
msgstr ""

#: 138b82f54e4e49d9a2b1d26d80a48bf6 of
#: tensormesh.operator.condense.Condenser.recover:3
msgid ""
"Scatters the condensed solution ``u`` back into the free-DOF slots and "
"writes the prescribed boundary values into the constrained slots."
msgstr ""

#: 86a3b170a7334d8fa31d1c2cb44c7653 of
#: tensormesh.operator.condense.Condenser.recover:7
msgid "Inner-system solution of shape :math:`[n_{\\text{inner\\_dof}}, \\ldots]`."
msgstr ""

#: 1c5ffac90a294ae68512f24b8830f7e8 of
#: tensormesh.operator.condense.Condenser.recover:11
msgid "Full-system solution of shape :math:`[n_{\\text{dof}}, \\ldots]`."
msgstr ""

#: 9f6f5f154d604a669bc38cee1230cb87 of
#: tensormesh.operator.condense.Condenser.restrict:1
msgid "Project a full-DOF vector down to inner DOFs."
msgstr ""

#: 96f6783f5bb94f17947d05812d615147 of
#: tensormesh.operator.condense.Condenser.restrict:3
msgid ""
"Pure linear restriction :math:`f_i \\leftarrow f|_{\\text{inner}}`, with "
"**no** Dirichlet-value correction. Use this when the right-hand side has "
"no implicit Dirichlet contribution to subtract — for example, the per-"
"stage right-hand side of a time-integration scheme such as "
":class:`tensormesh.ode.ImplicitLinearRungeKutta`, where the time-"
"derivative at a Dirichlet DOF is zero by construction and so the "
":math:`-K_{io}\\,u_o` term in :meth:`condense_rhs` would over-apply the "
"boundary correction."
msgstr ""

#: 20e7c97ca7ff4f9da576e0ecb05561be of
#: tensormesh.operator.condense.Condenser.restrict:13
msgid ""
"Unlike ``Condenser.__call__`` / :meth:`condense_rhs`, ``restrict`` does "
"not require the matrix layout to be cached first: it only needs "
"``dirichlet_mask``."
msgstr ""

#: 41817164005543fe983da63542288f1e of
#: tensormesh.operator.condense.Condenser.restrict:17
msgid "Full-DOF vector of shape :math:`[n_{\\text{dof}}, \\ldots]`."
msgstr ""

#: 645b60d021604a0ab5ef88ee9b6c46f4 fa1a01c4995746baaeae096b5452e626 of
#: tensormesh.operator.condense.Condenser.prolong:15
#: tensormesh.operator.condense.Condenser.restrict:21
msgid "Inner-DOF vector of shape :math:`[n_{\\text{inner\\_dof}}, \\ldots]`."
msgstr ""

#: b369cfe91bb140ffb3029bcebf16cb54 of
#: tensormesh.operator.condense.Condenser.prolong:1
msgid "Lift an inner-DOF vector up to full DOF with zeros on the boundary."
msgstr ""

#: 54f04d25f87e4024900f22c95f03a257 of
#: tensormesh.operator.condense.Condenser.prolong:3
msgid ""
"Pure linear prolongation: inner entries are scattered into the free-DOF "
"slots, constrained slots are filled with **zero** — not with "
"``dirichlet_value``. Use this when the quantity being lifted should "
"vanish on the boundary regardless of the prescribed Dirichlet value, e.g."
" the per-stage slope of a time integrator (since a fixed-value DOF has "
"zero time-derivative)."
msgstr ""

#: 3607f5b1736c4c04bd734fa2cb9b8989 of
#: tensormesh.operator.condense.Condenser.prolong:11
msgid ""
"Like :meth:`restrict`, ``prolong`` only needs ``dirichlet_mask`` and does"
" not require the matrix layout to be cached first."
msgstr ""

#: 78faf46bfce8476b834828d57404804a of
#: tensormesh.operator.condense.Condenser.prolong:19
msgid ""
"Full-DOF vector of shape :math:`[n_{\\text{dof}}, \\ldots]` with zeros in"
" the constrained slots."
msgstr ""

