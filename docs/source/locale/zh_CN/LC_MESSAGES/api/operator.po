#: 4b0a4709b1424e229b4982cb716b27db of tensormesh.operator.condense.Condenser:3
msgid ""
"Partitions a global system :math:`K u = f` into inner (free) DOFs and "
"outer (Dirichlet) DOFs and condenses the prescribed values into the "
"right-hand side:"
msgstr ""

#: a82d36d747d146cca9bccc0331c7198d of tensormesh.operator.condense.Condenser:7
#, python-brace-format
msgid "K_{ii}\\, u_i = f_i - K_{io}\\, u_o."
msgstr ""

