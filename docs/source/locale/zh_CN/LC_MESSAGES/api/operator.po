#: c0add1db975a4dc2a09432c57b043cef of
#: tensormesh.operator.condense.Condenser:87
msgid ""
":class:`Condenser` is a :class:`torch.nn.Module`. All tensor-valued "
"attributes (``dirichlet_mask``, ``dirichlet_value``, and the lazily "
"computed index buffers) are registered as PyTorch buffers, so "
"``condenser.to(device)`` / ``condenser.cuda()`` / ``condenser.cpu()`` "
"move them together with the input system."
msgstr ""

#: a091c1676fb3423f94d683a49ac5eef2 of
#: tensormesh.operator.condense.Condenser:93
msgid ""
"The first call to ``__call__`` lazily computes the inner / outer edge "
"masks and caches them on the instance. Subsequent calls reuse the cached "
"layout as long as the input :class:`~tensormesh.sparse.SparseMatrix` has "
"the same sparsity pattern (checked via ``matrix.layout_hash``). The lazy "
"buffers are registered with ``persistent=False`` so they are not saved "
"into ``state_dict``."
msgstr ""

#: 7572cd264c154f6e8ba486bd0ff9baec of
#: tensormesh.operator.condense.Condenser:101
msgid "Examples"
msgstr ""

#: b0fcf7b684d741f8ae82503f8187da89 of
#: tensormesh.operator.condense.Condenser:123
msgid ""
"For time-dependent boundary data, update the prescribed values between "
"solves via :meth:`update_dirichlet`, then re-condense only the right-hand"
" side with :meth:`condense_rhs` (cheaper than rebuilding ``K_inner``)."
msgstr ""

#: 19d0a0915455497aa292ec0e326362d6 of
#: tensormesh.operator.condense.Condenser.__init__:1
msgid ""
"Initialize internal Module state, shared by both nn.Module and "
"ScriptModule."
msgstr ""

#: 53b405e85b294b3eb867087edca9ba25 of
#: tensormesh.operator.condense.Condenser.update_dirichlet:1
msgid "Replace the cached prescribed boundary values."
msgstr ""

#: 238c12fd46734e3e887008f686f929d8 of
#: tensormesh.operator.condense.Condenser.update_dirichlet:3
#, python-brace-format
msgid ""
"Useful for time-dependent or parameter-swept problems where only the "
"right-hand side changes between solves; the cached :math:`K_{io}` block "
"(populated by ``__call__``) is preserved."
msgstr ""

#: 270f777f99df413296caaaf56496c277 of
#: tensormesh.operator.condense.Condenser.update_dirichlet:7
msgid ""
"1D tensor of shape :math:`[n_{\\text{dof}}]` or "
":math:`[n_{\\text{outer\\_dof}}]`, with the same conventions as the "
"``dirichlet_value`` argument to :meth:`__init__`."
msgstr ""

#: 38f6f941b98348a6b2bab4bdb250e3f3 of
#: tensormesh.operator.condense.Condenser.condense_rhs:1
msgid "Condense the right-hand side only, reusing the cached matrix layout."
msgstr ""

#: 1d3562aa020a44518b902cfa19666da3 of
#: tensormesh.operator.condense.Condenser.condense_rhs:3
#, python-brace-format
msgid "f_i \\leftarrow f_i - K_{io}\\, u_o."
msgstr ""

#: af52bd0b1376480986d745805f5b8535 of
#: tensormesh.operator.condense.Condenser.condense_rhs:7
msgid ""
"Use this after a first ``__call__`` to re-condense ``f`` when the matrix "
"is unchanged but the load vector changes (e.g. between time steps)."
msgstr ""

#: 23be9ee9533c4c4f99d3919eec0caf6d of
#: tensormesh.operator.condense.Condenser.condense_rhs:11
msgid "Global right-hand side of shape :math:`[n_{\\text{dof}}, \\ldots]`."
msgstr ""

