#: f7f8462a3b6d422d9e7dfb42d0b3c961 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:30
msgid "The infinitesimal strain tensor:"
msgstr ""

#: f87dd1fb705f4b8583de2b61386803c3 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:32
#, python-brace-format
msgid ""
"\\boldsymbol{\\varepsilon} = \\frac{1}{2}(\\nabla \\mathbf{u} + \\nabla "
"\\mathbf{u}^T)"
