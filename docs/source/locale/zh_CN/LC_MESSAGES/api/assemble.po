#: 29b9aa4f1b96419d88ea65452745c04e of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:38
#, python-brace-format
msgid ""
"\\int_{\\Omega} \\boldsymbol{\\sigma}(\\mathbf{u}) : "
"\\boldsymbol{\\varepsilon}(\\mathbf{v}) \\, \\mathrm{d}\\Omega\n"
"= \\int_{\\Omega} \\mathbf{f} \\cdot \\mathbf{v} \\, \\mathrm{d}\\Omega\n"
"+ \\int_{\\Gamma_N} \\mathbf{t} \\cdot \\mathbf{v} \\, \\mathrm{d}S"
msgstr ""

#: d3a4d3498dcd4003a1fe389a4efeeb39 d6204b3f463e49c88a9d10353da1cfdc of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:44
#: tensormesh.assemble.builtin.NeoHookeanModel:19
msgid "**Strain Energy Density:**"
msgstr ""

#: 579c8a92ca774c58aa3922fe38829370 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:46
#, python-brace-format
msgid ""
"\\Psi = \\frac{1}{2} \\boldsymbol{\\varepsilon} : \\mathbf{C} : "
"\\boldsymbol{\\varepsilon}\n"
"= \\frac{\\lambda}{2} (\\mathrm{tr}\\, \\boldsymbol{\\varepsilon})^2 + "
"\\mu \\, \\boldsymbol{\\varepsilon} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: dd892e3d2092411d88f3d661e708207b e6298f55f0e24cd4a113a8b0e97df2f9 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:51
#: tensormesh.assemble.builtin.NeoHookeanModel:40
