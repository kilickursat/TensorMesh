#: 70541092b90b40df93802072c6d25c44 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:19
#, python-brace-format
msgid ""
"K_{ij}^e = \\int_{\\Omega^e} \\nabla N_i \\cdot \\nabla N_j \\, "
"\\mathrm{d}\\Omega"
msgstr ""

#: 62f26202776e46b99e4058bfa68d11cb 75c283946e7e4c5fa41b71b6c1f76501 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:23
#: tensormesh.assemble.builtin.MassElementAssembler:20
