#: 97bbd979048c417eb61ef559641a881a of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:11
#, python-brace-format
msgid ""
"\\int_{\\Omega} \\kappa \\nabla u \\cdot \\nabla v \\, \\mathrm{d}\\Omega"
" = \\int_{\\Omega} f v \\, \\mathrm{d}\\Omega"
msgstr ""

#: ba36b249aac84144b59cd6dc74ffbece of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:15
