#: ca6c58cd1238463893d343315f457157 of
#: tensormesh.assemble.builtin.NeoHookeanModel:1
msgid "Neo-Hookean Hyperelastic Material Model."
msgstr ""

#: b4e0ea5e5a8145f1b2ddf856a52fe106 of
#: tensormesh.assemble.builtin.NeoHookeanModel:3
msgid ""
"A nonlinear hyperelastic constitutive model for large deformation "
"analysis. The Neo-Hookean model is the simplest hyperelastic model and "
"extends linear elasticity to the finite strain regime."
msgstr ""

#: b3e4966307404d5fbbae1ab8eacaea7a of
#: tensormesh.assemble.builtin.NeoHookeanModel:7
msgid "**Deformation Gradient:**"
msgstr ""

#: 008a01d308214dfdad208c53d7d36a06 of
#: tensormesh.assemble.builtin.NeoHookeanModel:9
#, python-brace-format
msgid "\\mathbf{F} = \\mathbf{I} + \\nabla \\mathbf{u}"
msgstr ""

#: b11a8fd2218f4a2484f4fbace2963f18 of
#: tensormesh.assemble.builtin.NeoHookeanModel:13
msgid "**Kinematic Quantities:**"
msgstr ""

#: d2d3c50f22124c8fbf17b20b2a61777f of
#: tensormesh.assemble.builtin.NeoHookeanModel:15
#, python-brace-format
msgid "Right Cauchy-Green tensor: :math:`\\mathbf{C} = \\mathbf{F}^T \\mathbf{F}`"
msgstr ""

#: 1e34d4fa3af84c9db2137ef649ac6725 of
#: tensormesh.assemble.builtin.NeoHookeanModel:16
#, python-brace-format
msgid ""
"First invariant: :math:`I_1 = \\mathrm{tr}(\\mathbf{C}) = "
"\\|\\mathbf{F}\\|_F^2`"
msgstr ""

#: 175bf0d10c404935baeb4be0fd650783 of
#: tensormesh.assemble.builtin.NeoHookeanModel:17
#, python-brace-format
msgid "Jacobian (volume ratio): :math:`J = \\det(\\mathbf{F})`"
msgstr ""

#: b9b279f80c1344ae86597bd86f13f8e4 ebd1aaf0351b4c73aee10977e3744581 of
#: tensormesh.assemble.builtin.NeoHookeanModel:21
#: tensormesh.assemble.builtin.NeoHookeanModel.element_energy:3
#, python-brace-format
msgid ""
"\\Psi = \\frac{\\mu}{2}(I_1 - d) - \\mu \\ln J + \\frac{\\lambda}{2}(\\ln"
" J)^2"
msgstr ""

#: c651e89c178647519ec7fba38367c7e6 of
#: tensormesh.assemble.builtin.NeoHookeanModel:25
msgid "where :math:`d` is the spatial dimension (2 or 3)."
msgstr ""

#: cd6143c830134b0084b384f54e58faea of
#: tensormesh.assemble.builtin.NeoHookeanModel:27
msgid "**First Piola-Kirchhoff Stress:**"
msgstr ""

#: f631f8277a4f458bbef9e618cdf55a8b of
#: tensormesh.assemble.builtin.NeoHookeanModel:29
msgid ""
"\\mathbf{P} = \\frac{\\partial \\Psi}{\\partial \\mathbf{F}}\n"
"= \\mu \\mathbf{F} + (\\lambda \\ln J - \\mu) \\mathbf{F}^{-T}"
msgstr ""

#: c2f73785f45e4297a285dc0c74d8cf45 of
#: tensormesh.assemble.builtin.NeoHookeanModel:34
msgid "**Material Parameters:**"
msgstr ""

#: 8f23b1f440c540189f509b8259b9bda9 of
#: tensormesh.assemble.builtin.NeoHookeanModel:36
#, python-brace-format
msgid ""
"\\mu = \\frac{E}{2(1+\\nu)}, \\quad \\lambda = "
"\\frac{E\\nu}{(1+\\nu)(1-2\\nu)}"
msgstr ""

