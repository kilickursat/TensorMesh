#: 5b203007bcfe472c91511b4b551066d8 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:16
#, python-brace-format
msgid ""
"C_{ijkl} = \\lambda \\delta_{ij} \\delta_{kl} + \\mu "
"(\\delta_{ik}\\delta_{jl} + \\delta_{il}\\delta_{jk})"
msgstr ""

#: 5d206334ab504d99ae9a8f32f27cf1aa of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:20
msgid "**Lamé Parameters:**"
