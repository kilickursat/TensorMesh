#: ac80845af1054aa8b851103de90a8347 of
#: tensormesh.assemble.builtin.J2Plasticity:42
#, python-brace-format
msgid ""
"Check yield: :math:`f^{tr} = \\|\\mathbf{s}^{tr}\\| - "
"\\sqrt{2/3}(\\sigma_0 + H\\alpha_n)`"
msgstr ""

#: 695fb4a8b506414ea53af9e27f1dbf9e of
#: tensormesh.assemble.builtin.J2Plasticity:43
#, python-brace-format
msgid "If :math:`f^{tr} \\leq 0`: elastic step, accept trial state"
