#: 9911e67bca904cb0b03b8138f0fbf96a of
#: tensormesh.assemble.element_assembler.ElementAssembler:1
msgid "Assemble an element-wise bilinear form into a global sparse matrix."
msgstr ""

#: 527f97332d734051941e894c4de8b609 of
#: tensormesh.assemble.element_assembler.ElementAssembler:3
#, python-brace-format
msgid ""
":class:`ElementAssembler` is an :class:`torch:torch.nn.Module` whose "
":meth:`forward` defines the integrand of a bilinear form :math:`a(u, v) ="
" \\int_\\Omega f(u, v)\\, \\mathrm{d}\\Omega`. Calling the assembler "
"integrates :math:`f` over every quadrature point of every element and "
"scatters the result into a :class:`~tensormesh.sparse.SparseMatrix` of "
"shape :math:`[|\\mathcal V|, |\\mathcal V|]` (scalar problems) or "
":math:`[|\\mathcal V| \\times H, |\\mathcal V| \\times H]` (vector "
"problems with :math:`H` degrees of freedom per node)."
msgstr ""

#: 6b137b3d885347ba8fc243147fd7e5cb e250809b75b04c45881d4161d75b6f4e of
#: tensormesh.assemble.element_assembler.ElementAssembler:12
#: tensormesh.assemble.node_assembler.NodeAssembler:10
msgid "Subclasses are usually built from a mesh:"
msgstr ""

#: 58310b1c913e45b8849cdebb8491eb22 of
#: tensormesh.assemble.element_assembler.ElementAssembler:14
#, python-brace-format
msgid ""
":meth:`from_mesh` — build from a :class:`~tensormesh.Mesh` (slower; "
"precomputes the projection tensor :math:`\\mathcal P_{\\mathcal E}`)."
msgstr ""

#: 1ee3973cadd8433783a46f8d33f0d828 of
#: tensormesh.assemble.element_assembler.ElementAssembler:16
msgid ":meth:`from_assembler` — share the topology of another assembler (fast)."
msgstr ""

#: 44aa0b9aa14f47f1803f2ec1fa85003c of
#: tensormesh.assemble.element_assembler.ElementAssembler:18
msgid "The schematic of one ``__call__`` is"
msgstr ""

#: 5831f870964246f4a8c9cc5a1d56d5eb of
#: tensormesh.assemble.element_assembler.ElementAssembler:20
msgid ""
"K \\overset{\\text{bsr matrix}}{\\leftarrow}\\hat K_\\text{global},\n"
"\\qquad\n"
"\\hat K_{\\text{global}}^{nkl} = \\mathcal P_{\\mathcal E}^{nhij}\\, "
"\\hat K_{\\text{local}}^{hklij},\n"
"\\qquad\n"
"\\hat K_{ij} = \\int_\\Omega f(u, v)\\, \\mathrm{d}\\Omega,"
msgstr ""

#: 41ca7619f3d8463a8e3c78e702f1d343 of
#: tensormesh.assemble.element_assembler.ElementAssembler:28
msgid "where"
msgstr ""

#: d8038b1d13c048d6a7546bad7300b580 of
#: tensormesh.assemble.element_assembler.ElementAssembler:30
msgid ""
":math:`\\hat K_{\\text{global}}` are the non-zero entries of the global "
"Galerkin matrix, :math:`K_{\\text{global}} \\in \\mathbb R^{|\\mathcal "
"E|\\times d \\times d}`;"
msgstr ""

#: e25788694c814c7bac9e916bbc571977 of
#: tensormesh.assemble.element_assembler.ElementAssembler:32
msgid ""
":math:`\\hat K_{\\text{local}}` is the per-element Galerkin block, "
":math:`K_{\\text{local}} \\in \\mathbb R^{|\\mathcal C|\\times h \\times "
"h \\times d \\times d}`;"
msgstr ""

#: e827001fc1ce40e4b88b89a273c52a82 of
#: tensormesh.assemble.element_assembler.ElementAssembler:34
msgid ""
":math:`\\mathcal P_{\\mathcal E} \\in \\mathbb "
"R_{\\text{sparse}}^{|\\mathcal E|\\times|\\mathcal C|\\times h \\times "
"h}` is the projection (assemble) tensor from local to global;"
msgstr ""

#: 5e3b61051cee43d3b9add2b966bb3eb5 of
#: tensormesh.assemble.element_assembler.ElementAssembler:36
msgid ""
":math:`\\mathcal C` indexes elements/cells, :math:`\\mathcal E` indexes "
"edges (the unique ``(i, j)`` pairs of basis indices), :math:`\\mathcal V`"
" indexes nodes/vertices, and :math:`h` is the number of basis functions "
"per element."
msgstr ""

