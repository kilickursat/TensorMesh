#: 7821cfb5d36446e2970abd369c770b02 of
#: tensormesh.assemble.builtin.J2Plasticity:15
#, python-brace-format
msgid ""
":math:`\\mathbf{s} = \\boldsymbol{\\sigma} - "
"\\frac{1}{3}\\mathrm{tr}(\\boldsymbol{\\sigma})\\mathbf{I}` is the "
"deviatoric stress"
msgstr ""

#: 08c2dff06e2c4184bc5bf157c308e1ac of
#: tensormesh.assemble.builtin.J2Plasticity:16
msgid ":math:`\\sigma_0` is the initial yield stress"
