#: abc328e8fa3c47718f3f1db2e53d05a5 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:1
msgid "Compute strain energy density at a quadrature point."
msgstr ""

#: 84596f7bc2ac433a89f017aeb4bf1e08 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:3
#, python-brace-format
msgid ""
"\\Psi = \\frac{\\lambda}{2} (\\mathrm{tr}\\, "
"\\boldsymbol{\\varepsilon})^2\n"
"+ \\mu \\, \\boldsymbol{\\varepsilon} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: 7c21885f5f3849e6afd749a90e0dbf5f 804cb7a183eb44c98a506b9a299f1b84 of
