#: 49cd66382f7e4d8fb3a19e0873e7b70a of
#: tensormesh.assemble.builtin.J2Plasticity:17
msgid ":math:`H` is the hardening modulus"
msgstr ""

#: 1b942fd0eff74bf9839002fe72db8402 of
#: tensormesh.assemble.builtin.J2Plasticity:18
msgid ":math:`\\alpha` is the equivalent plastic strain (internal variable)"
msgstr ""

#: e515246e4b604283a4a3c775a64aea00 of
#: tensormesh.assemble.builtin.J2Plasticity:20
msgid "**Additive Strain Decomposition:**"
msgstr ""

#: f22ee3b5114644328bf7c36efab5cf3d of
#: tensormesh.assemble.builtin.J2Plasticity:22
#, python-brace-format
msgid ""
"\\boldsymbol{\\varepsilon} = \\boldsymbol{\\varepsilon}^e + "
"\\boldsymbol{\\varepsilon}^p"
