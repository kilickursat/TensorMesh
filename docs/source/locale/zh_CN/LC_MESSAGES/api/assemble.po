#: b56fddd8175b45c7a013aa1722095f4d of
#: tensormesh.assemble.builtin.J2Plasticity:44
#, python-brace-format
msgid "If :math:`f^{tr} > 0`: plastic correction"
msgstr ""

#: 0b605f4e09f64d79b99f4bc6437b1de4 of
#: tensormesh.assemble.builtin.J2Plasticity:46
msgid "\\Delta\\gamma = \\frac{f^{tr}}{2\\mu + \\frac{2}{3}H}"
msgstr ""

#: ec0eaa8dcb4b41f9a603ad1ddfa7e4d1 of
#: tensormesh.assemble.builtin.J2Plasticity:50
msgid "**Algorithmic Incremental Potential:**"
msgstr ""

#: 552f8b5e3d9d421fb675bb1a57d249a7 of
#: tensormesh.assemble.builtin.J2Plasticity:52
#, python-brace-format
msgid ""
"\\Psi^{alg} = \\frac{K}{2}(\\mathrm{tr}\\,\\boldsymbol{\\varepsilon}^e)^2"
"\n"
"+ \\mu \\|\\mathbf{e}^{tr}\\|^2 - \\frac{1}{2}(2\\mu + "
"\\frac{2}{3}H)(\\Delta\\gamma)^2"
