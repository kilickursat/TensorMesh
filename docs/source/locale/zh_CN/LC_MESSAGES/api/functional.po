"f(\\sigma_{\\text{trial}}) = \\|\\text{dev}(\\sigma_{\\text{trial}})\\| -"
" \\sigma_y\n"
"\n"
"\\Delta\\gamma = \\frac{\\langle f(\\sigma_{\\text{trial}}) "
"\\rangle}{\\|\\text{dev}(\\sigma_{\\text{trial}})\\|}\n"
"\n"
"\\sigma = \\sigma_{\\text{trial}} - \\Delta\\gamma\\, "
"\\text{dev}(\\sigma_{\\text{trial}})"
