#: b80396b51ee44036a68c5166dac7ac3f of
#: tensormesh.functional.elasticity.voigt_shape_grad:1
msgid "Convert displacement gradient to Voigt notation for strain calculation."
msgstr ""

#: 740dd40f30ef405ab0fabcf6742d8fbd of
#: tensormesh.functional.elasticity.voigt_shape_grad:5
#, python-brace-format
msgid ""
"B \\in \\mathbb{R}^{3 \\times (2\\times 3)} = \\begin{bmatrix}\n"
"    \\frac{\\partial u_1}{\\partial x_1} & 0 & \\mid & \\frac{\\partial "
"u_2}{\\partial x_1} & 0 & \\mid & \\frac{\\partial u_3}{\\partial x_1} & "
"0 \\\\\n"
"    0 & \\frac{\\partial u_1}{\\partial x_2} & \\mid & 0 & "
"\\frac{\\partial u_2}{\\partial x_2} & \\mid & 0 & \\frac{\\partial "
"u_3}{\\partial x_2} \\\\\n"
"    \\frac{\\partial u_1}{\\partial x_2} & \\frac{\\partial "
"u_1}{\\partial x_1} & \\mid & \\frac{\\partial u_2}{\\partial x_2} & "
"\\frac{\\partial u_2}{\\partial x_1} & \\mid & \\frac{\\partial "
"u_3}{\\partial x_2} & \\frac{\\partial u_3}{\\partial x_1}\n"
"\\end{bmatrix}"
msgstr ""

#: 54b4b4c6439243a6bd71a69b2d1d62a9 5d1110836b0b416582fc1f9493f8e8f3 of
#: tensormesh.functional.elasticity.voigt_shape_grad:13
#: tensormesh.functional.elasticity.voigt_stiffness:11
#, python-brace-format
msgid "representing [:math:`\\varepsilon_{xx}, \\varepsilon_{yy}, \\gamma_{xy}`]"
msgstr ""

#: 8c9453b26e164a4ba3320ef0de5e01f6 e4b7c7cb35c04419b711e556e1febfd5 of
#: tensormesh.functional.elasticity.voigt_shape_grad:17
#: tensormesh.functional.elasticity.voigt_shape_grad:42
#, python-brace-format
msgid ":math:`u_i \\in \\mathbb{R}` is the displacement component in direction i"
msgstr ""

#: 3a3b937a8be54fb9938817f3e2a40938 fb02f1c25a0946c0ac19397b57400656 of
#: tensormesh.functional.elasticity.voigt_shape_grad:18
#: tensormesh.functional.elasticity.voigt_shape_grad:43
#, python-brace-format
msgid ":math:`x_i \\in \\mathbb{R}` is the spatial coordinate in direction i"
msgstr ""

#: 5bb40f8c1c4740aebb01be7fc5d2b14f 9abb540d22534f83bdb02ecaf012852e of
#: tensormesh.functional.elasticity.voigt_shape_grad:19
#: tensormesh.functional.elasticity.voigt_shape_grad:44
#, python-brace-format
msgid ""
":math:`\\frac{\\partial u_i}{\\partial x_j} \\in \\mathbb{R}` is the "
"partial derivative of displacement i with respect to coordinate j"
msgstr ""

#: b34aa3a849504d00adae94b2a1682357 of
#: tensormesh.functional.elasticity.voigt_shape_grad:25
#, python-brace-format
msgid ""
"B \\in \\mathbb{R}^{6 \\times (3\\times 3)} = \\begin{bmatrix}\n"
"    \\frac{\\partial u_1}{\\partial x_1} & 0 & 0 & \\mid & "
"\\frac{\\partial u_2}{\\partial x_1} & 0 & 0 & \\mid & \\frac{\\partial "
"u_3}{\\partial x_1} & 0 & 0 \\\\\n"
"    0 & \\frac{\\partial u_1}{\\partial x_2} & 0 & \\mid & 0 & "
"\\frac{\\partial u_2}{\\partial x_2} & 0 & \\mid & 0 & \\frac{\\partial "
"u_3}{\\partial x_2} & 0 \\\\\n"
"    0 & 0 & \\frac{\\partial u_1}{\\partial x_3} & \\mid & 0 & 0 & "
"\\frac{\\partial u_2}{\\partial x_3} & \\mid & 0 & 0 & \\frac{\\partial "
"u_3}{\\partial x_3} \\\\\n"
"    0 & \\frac{\\partial u_1}{\\partial x_3} & \\frac{\\partial "
"u_1}{\\partial x_2} & \\mid & 0 & \\frac{\\partial u_2}{\\partial x_3} & "
"\\frac{\\partial u_2}{\\partial x_2} & \\mid & 0 & \\frac{\\partial "
"u_3}{\\partial x_3} & \\frac{\\partial u_3}{\\partial x_2} \\\\\n"
"    \\frac{\\partial u_1}{\\partial x_3} & 0 & \\frac{\\partial "
"u_1}{\\partial x_1} & \\mid & \\frac{\\partial u_2}{\\partial x_3} & 0 & "
"\\frac{\\partial u_2}{\\partial x_1} & \\mid & \\frac{\\partial "
"u_3}{\\partial x_3} & 0 & \\frac{\\partial u_3}{\\partial x_1} \\\\\n"
"    \\frac{\\partial u_1}{\\partial x_2} & \\frac{\\partial "
"u_1}{\\partial x_1} & 0 & \\mid & \\frac{\\partial u_2}{\\partial x_2} & "
"\\frac{\\partial u_2}{\\partial x_1} & 0 & \\mid & \\frac{\\partial "
"u_3}{\\partial x_2} & \\frac{\\partial u_3}{\\partial x_1} & 0\n"
"\\end{bmatrix}"
msgstr ""

