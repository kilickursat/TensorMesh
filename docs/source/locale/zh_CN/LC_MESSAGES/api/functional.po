#: c5147524a0e243938b8b131f78fa04b0 of tensormesh.functional.ops.skew:23
#, python-brace-format
msgid ""
"\\text{skew}(v) = \\begin{cases}\n"
"    \\begin{bmatrix}\n"
"        0 & -v_3 & v_2 \\\\\n"
"        v_3 & 0 & -v_1 \\\\\n"
"        -v_2 & v_1 & 0\n"
"    \\end{bmatrix} & \\text{if sign=True} \\\\[1em]\n"
"    \\begin{bmatrix}\n"
"        0 & v_3 & v_2 \\\\\n"
"        v_3 & 0 & v_1 \\\\\n"
"        v_2 & v_1 & 0\n"
"    \\end{bmatrix} & \\text{if sign=False}\n"
"\\end{cases}"
msgstr ""

