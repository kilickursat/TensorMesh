#, python-brace-format
msgid ""
"\\text{skew}\\left(\\begin{bmatrix}\n"
"    v_1 \\\\\n"
"    v_2\n"
"\\end{bmatrix}\\right) = \\begin{cases}\n"
"    \\begin{bmatrix}\n"
"        -v_2 \\\\\n"
"        v_1\n"
"    \\end{bmatrix} & \\text{if sign=True} \\\\[1em]\n"
"    \\begin{bmatrix}\n"
"        v_2 \\\\\n"
"        v_1\n"
"    \\end{bmatrix} & \\text{if sign=False}\n"
"\\end{cases}"
msgstr ""

