#: ../../source/performance/benchmarks.rst:162 b566ad91df2f46d081a40adc2cb7230c
msgid "3D linear elasticity"
msgstr ""

#: ../../source/performance/benchmarks.rst:164 5435acf8dfc4486d9d3a03028346f572
msgid "We solve the static equilibrium of an isotropic linear elastic body:"
msgstr ""

#: ../../source/performance/benchmarks.rst:166 32e1d3f8d30e44f3bc53848c335371e3
#, python-brace-format
msgid ""
"\\begin{cases}\n"
"    -\\nabla \\cdot \\boldsymbol{\\sigma}(\\mathbf{x}) = "
"\\mathbf{f}(\\mathbf{x}) & \\text{in } \\Omega, \\\\\n"
"    \\mathbf{u}(\\mathbf{x}) = \\mathbf{0} & \\text{on } "
"\\partial\\Omega,\n"
"\\end{cases}"
msgstr ""

#: ../../source/performance/benchmarks.rst:173 30fb8c27ca0c473099208aee19d7edd5
#, python-brace-format
msgid ""
"where :math:`\\mathbf{u} : \\Omega \\to \\mathbb{R}^3` is the "
"displacement and the Cauchy stress satisfies Hooke's law"
msgstr ""

#: ../../source/performance/benchmarks.rst:176 9baebf2f36c841a69f7a728f93d02f44
#, python-brace-format
msgid ""
"\\boldsymbol{\\sigma} = \\lambda \\, "
"\\mathrm{tr}(\\boldsymbol{\\varepsilon}) \\, \\mathbf{I}\n"
"+ 2\\mu \\, \\boldsymbol{\\varepsilon},\n"
"\\qquad\n"
"\\boldsymbol{\\varepsilon} = \\tfrac{1}{2}\\bigl(\\nabla \\mathbf{u} + "
"(\\nabla \\mathbf{u})^\\top\\bigr)."
msgstr ""

#: ../../source/performance/benchmarks.rst:183 224494ca877c428b9d79d6acc52d91c3
msgid ""
"We set Young's modulus :math:`E = 1` and Poisson's ratio :math:`\\nu = "
"0.3`, giving"
msgstr ""

#: ../../source/performance/benchmarks.rst:186 a558935204984d6291b86cc17adefd67
#, python-brace-format
msgid ""
"\\lambda = \\frac{E\\nu}{(1+\\nu)(1-2\\nu)},\n"
"\\qquad\n"
"\\mu = \\frac{E}{2(1+\\nu)}."
msgstr ""

#: ../../source/performance/benchmarks.rst:192 08c8e0f3a8e74b27bf008cfe746a8321
#, python-brace-format
msgid ""
"A constant body force :math:`\\mathbf{f} = (1,1,1)^\\top` is applied. To "
"introduce geometric complexity we use a hollow cube domain"
msgstr ""

#: ../../source/performance/benchmarks.rst:195 c6fe2f5b6b96494e8d3e758abe0f0c4a
msgid "\\Omega = [0,1]^3 \\setminus (0.25,\\, 0.75)^3."
msgstr ""

