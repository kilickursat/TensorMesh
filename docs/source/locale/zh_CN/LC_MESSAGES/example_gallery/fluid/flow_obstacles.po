#: 9675a427b7e84d50835e89634cb4bf4a
#, python-brace-format
msgid ""
"\\rho\\, (\\mathbf{u} \\cdot \\nabla)\\mathbf{u}\n"
"\\;=\\; -\\nabla p + \\mu\\, \\Delta \\mathbf{u}\n"
"\\quad \\text{in } \\Omega,\n"
"\\qquad \\nabla \\cdot \\mathbf{u} = 0,"
msgstr ""

#: ../../source/example_gallery/fluid/flow_obstacles.rst:24
#: d7b81ecd282f46fc95a78fe53284d6e5
msgid "with the channel :math:`(0, 3) \\times (0, 1)` minus six discs at"
msgstr ""

