#: ../../source/example_gallery/fluid/flow_obstacles.rst:44
#: b77fc165f64644259b2144d3f68f62b0
#, python-brace-format
msgid ""
"At :math:`\\mathrm{Re} = 150` the flow is steady (no shedding), the wake "
"of each obstacle interacts with the next, and the solution shows "
"characteristic narrow jets between the closely- spaced cylinders."
msgstr ""

