"(1.0, 0.3)\\!:\\,r\\!=\\!0.08, \\quad\n"
"(1.0, 0.7)\\!:\\,r\\!=\\!0.08,\n"
"\n"
"(1.5, 0.5)\\!:\\,r\\!=\\!0.12, \\quad\n"
"(2.0, 0.4)\\!:\\,r\\!=\\!0.07, \\quad\n"
"(2.0, 0.6)\\!:\\,r\\!=\\!0.07."
msgstr ""

