msgstr "对于基于 ``Condenser`` 的边界条件，返回……"

#: ../../source/user_guide/time_integration.rst:366
#: 1576eaab43b34054a6e80c55a104a5ed
msgid "``pre_solve_lhs(K)``"
msgstr "``pre_solve_lhs(K)``"

